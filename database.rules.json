{
  "rules": {
    // Matches - anyone can read, only admins can write
    "matches": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('admin').val() === true"
    },

    // Users - private profile data, including email
    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('admin').val() === true)",
        ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('admin').val() === true)",
        // Prevent non-admins from setting admin flag
        "admin": {
          ".write": "auth != null && root.child('users').child(auth.uid).child('admin').val() === true"
        }
      }
    },

    // Public user profile data for leaderboards and member lists
    "publicUsers": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('admin').val() === true || (auth.uid === $userId && (!newData.exists() || (!data.exists() && newData.child('score').val() === 0) || (data.exists() && newData.child('score').val() === data.child('score').val()))))"
      }
    },

    // Usernames index - anyone can read, special write rules
    "usernames": {
      ".read": true,
      "$normalizedUsername": {
        // Can write if: claiming for yourself OR releasing your own OR admin
        ".write": "auth != null && (newData.val() === auth.uid || !data.exists() || data.val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)"
      }
    },

    // Minimal username -> email index for username login. Exact-key lookup only.
    "userLoginEmails": {
      "$normalizedUsername": {
        ".read": true,
        ".write": "auth != null && ((newData.exists() && newData.val() === root.child('users').child(auth.uid).child('email').val()) || (!newData.exists() && data.val() === root.child('users').child(auth.uid).child('email').val()) || root.child('users').child(auth.uid).child('admin').val() === true)"
      }
    },

    // Predictions - anyone can read, users can only write their own (admins can write any)
    "predictions": {
      "$userId": {
        // Anyone can read predictions (to view other users' predictions)
        ".read": true,
        // Users can delete their own predictions (for account deletion), admins can write/delete all
        ".write": "auth != null && ((auth.uid === $userId && !newData.exists()) || root.child('users').child(auth.uid).child('admin').val() === true)",
        "$gameId": {
          // Users can write their own predictions at least 10 mins before kickoff
          // Admins can write any predictions (for mock data)
          // Match timestamp is in seconds, now is in milliseconds
          ".write": "auth != null && ((auth.uid === $userId && now < root.child('matches').child($gameId).child('timestamp').val() * 1000 - 600000) || root.child('users').child(auth.uid).child('admin').val() === true)",
          // Validate prediction structure
          ".validate": "newData.hasChildren(['homePrediction', 'awayPrediction', 'points', 'updatedAt'])",
          "homePrediction": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
          },
          "awayPrediction": {
            ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 99"
          },
          "points": {
            // Users can only set points to 0, admins/functions can set any value
            ".validate": "newData.isNumber() && newData.val() >= 0 && (newData.val() === 0 || root.child('users').child(auth.uid).child('admin').val() === true)"
          },
          "updatedAt": {
            ".validate": "newData.isNumber()"
          }
        }
      }
    },

    // Leagues - anyone can read, owner can write
    "leagues": {
      ".read": true,
      "$leagueId": {
        // Only owner can update league settings
        ".write": "auth != null && (data.child('ownerId').val() === auth.uid || !data.exists())"
      }
    },

    // League slugs index - maps slug to leagueId
    "leagueSlugs": {
      ".read": true,
      "$slug": {
        ".write": "auth != null && (!data.exists() || root.child('leagues').child(data.val()).child('ownerId').val() === auth.uid)"
      }
    },

    // Invite codes index - allows lookup by exact code without listing all codes
    "inviteCodes": {
      "$code": {
        ".read": true,
        ".write": "auth != null && (root.child('users').child(auth.uid).child('admin').val() === true || (data.exists() && root.child('leagues').child(data.val()).child('ownerId').val() === auth.uid) || (!data.exists() && newData.exists() && root.child('leagues').child(newData.val()).child('ownerId').val() === auth.uid))"
      }
    },

    // League secrets - readable only by league members/owner/admin
    "leagueSecrets": {
      "$leagueId": {
        ".read": "auth != null && (root.child('leagueMembers').child($leagueId).child(auth.uid).exists() || root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)",
        ".write": "auth != null && (root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)"
      }
    },

    // League members - who is in each league
    "leagueMembers": {
      ".read": true,
      "$leagueId": {
        // Allow owner or admin to delete the entire member list (for league deletion)
        ".write": "auth != null && (root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true)",
        "$userId": {
          // Users can remove themselves. Joining requires the invite code. Owner/admin can manage anyone.
          ".write": "auth != null && (root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true || (auth.uid === $userId && (!newData.exists() || newData.child('inviteCode').val() === root.child('leagueSecrets').child($leagueId).child('inviteCode').val() || newData.child('inviteCode').val() === root.child('leagues').child($leagueId).child('inviteCode').val())))"
        }
      }
    },

    // User leagues - reverse index for quick lookup of user's leagues
    "userLeagues": {
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        // Users can delete their entire userLeagues entry (for account deletion)
        ".write": "auth != null && auth.uid === $userId && !newData.exists()",
        "$leagueId": {
          // Users can add this reverse index only after leagueMembers was validated.
          ".write": "auth != null && (root.child('leagues').child($leagueId).child('ownerId').val() === auth.uid || root.child('users').child(auth.uid).child('admin').val() === true || (auth.uid === $userId && (!newData.exists() || root.child('leagueMembers').child($leagueId).child($userId).exists())))"
        }
      }
    },

    // Default deny all other paths
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
